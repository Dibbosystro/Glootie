# Private v1 access. If APP_ACCESS_PASSWORD is empty, the app runs open in local/dev.
APP_ACCESS_PASSWORD=
AUTH_COOKIE_SECRET=replace-with-a-long-random-string
CRON_SECRET=replace-with-a-long-random-string
CREDENTIAL_ENCRYPTION_KEY=replace-with-a-different-long-random-string

# Database, provision Neon/Postgres on Vercel and paste DATABASE_URL.
DATABASE_URL=

# Shopify Admin API
SHOPIFY_STORE_DOMAIN=
SHOPIFY_ADMIN_ACCESS_TOKEN=

# Meta Marketing API
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=

# Google Ads API
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_REDIRECT_URI=

# AI providers, optional
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/auto
NEOKENS_KEY=
NEOKENS_BASE_URL=https://api.neokens.com/
NEOKENS_MODEL=claude-sonnet-4-6-thinking
